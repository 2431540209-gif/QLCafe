<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".fragment.FragmentTrangChu">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/newHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D0770B"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chào Mừng"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="HardcodedText" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAvatar"
            android:layout_width="64dp"
            android:layout_height="65dp"
            android:layout_marginTop="16dp"
            android:background="@android:color/white"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_account"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvGreeting"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvEmployeeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Tên Quan Ly"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toTopOf="@id/imgAvatar"
            tools:ignore="HardcodedText" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="#4DFFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toBottomOf="@id/tvEmployeeName">

            <TextView
                android:id="@+id/tvRoleName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Manager"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </com.google.android.material.card.MaterialCardView>

        <TextClock
            android:id="@+id/textClock2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChamCongHome"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:text="CHẤM CÔNG"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#D0770B"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_account"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                android:elevation="4dp"
                tools:ignore="HardcodedText" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDoanhThu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnGoToRevenue"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#FDE2CA"
                        app:cardCornerRadius="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_money_24"
                            app:tint="@android:color/black"
                            android:contentDescription="@null" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvdoanhthu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng doanh thu trong ngày"
                        android:textColor="#888888"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnGoToRevenue"
                        android:layout_marginEnd="16dp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvsodoanhthu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0đ"
                        android:textColor="#333333"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_below="@id/tvdoanhthu"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnGoToRevenue"
                        android:layout_marginEnd="16dp"
                        tools:ignore="HardcodedText" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDonhang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnGoToOrder"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#FDE2CA"
                        app:cardCornerRadius="12dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu"
                            app:tint="@android:color/black"
                            android:contentDescription="@null" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvdonhang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng đơn hàng"
                        android:textColor="#888888"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnGoToOrder"
                        android:layout_marginEnd="16dp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvsodonhang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="128"
                        android:textColor="#333333"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_below="@id/tvdonhang"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnGoToOrder"
                        android:layout_marginEnd="16dp"
                        tools:ignore="HardcodedText" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvNotifTarget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#E8F5E9"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="Toàn hệ thống"
                        android:textColor="#2E7D32"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvNotifTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1/1/2026 - 00:00"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_alignBaseline="@id/tvNotifTarget"
                        android:layout_alignParentEnd="true"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvNotifTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Chưa có thông báo nào"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_below="@id/tvNotifTarget"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvNotifContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Hôm nay hệ thống không có sự kiện gì mới."
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:layout_below="@id/tvNotifTitle"
                        tools:ignore="HardcodedText" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>