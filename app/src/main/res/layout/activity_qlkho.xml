<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F6F4">

    <include layout="@layout/layout_top_bar" />

    <!-- Ô tìm kiếm -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/edtSearch"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:hint="Tìm nguyên liệu..."
            android:background="@android:drawable/edit_text"/>

        <ImageButton
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginStart="10dp"
            android:src="@android:drawable/ic_menu_manage"
            android:background="#FFFFFF"/>
    </LinearLayout>

    <!-- Nút nhập xuất -->
    <LinearLayout
        android:id="@+id/layoutAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- Nhập kho -->
        <LinearLayout
            android:id="@+id/layoutNhapKho"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <Button
                android:id="@+id/btnNhapKho"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Nhập kho"
                android:textColor="#D32F2F"
                android:backgroundTint="#FFFFFF"/>
        </LinearLayout>

        <Space
            android:id="@+id/spaceButton"
            android:layout_width="12dp"
            android:layout_height="wrap_content"/>

        <!-- Xuất kho -->
        <Button
            android:id="@+id/btnXuatKho"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Xuất kho"
            android:textColor="#D32F2F"
            android:backgroundTint="#FFFFFF"/>

    </LinearLayout>

    <!-- Tiêu đề danh sách -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danh sách nguyên liệu"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="16dp"/>

    <!-- Danh sách nguyên liệu -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNguyenLieu"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>