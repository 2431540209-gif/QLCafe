<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tạo Thông Báo Mới"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#D0770B"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phân loại:"/>
    <Spinner
        android:id="@+id/spnLoaiThongBao"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"/>
    <LinearLayout
        android:id="@+id/layoutNguoiNhan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gửi riêng cho:"/>
        <Spinner
            android:id="@+id/spnNguoiNhan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"/>
    </LinearLayout>
    <EditText
        android:id="@+id/edtTieuDe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập tiêu đề (VD: Họp khẩn)"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/edtMoTa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mô tả ngắn ở ngoài danh sách"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/edtChiTiet"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Nhập nội dung chi tiết..."
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:background="#F5F5F5"
        android:padding="8dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnGuiThongBao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gửi Thông Báo"
        android:backgroundTint="#D0770B"/>
</LinearLayout>