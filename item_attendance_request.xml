<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvItemDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="29/06/2026"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="#FFF3CD"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Chưa duyệt"
            android:textColor="#856404"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemShift"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvItemDate"
            android:layout_marginTop="8dp"
            android:text="VAA CAFE-Ca phát sinh"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tvItemTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvItemShift"
            android:layout_marginTop="4dp"
            android:text="14:54 - 18:00"
            android:textColor="#0056B3"
            android:textStyle="bold" />
        <LinearLayout
            android:id="@+id/layoutManagerActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvItemTime"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTuChoi"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Từ chối"
            android:textColor="#D32F2F"
            app:strokeColor="#D32F2F" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDuyet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Duyệt đơn"
                app:backgroundTint="#388E3C" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStaffActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layoutManagerActions"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSua"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Sửa"
                android:textColor="#FF9800"
                app:strokeColor="#FF9800" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnXoa"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Xóa"
                android:textColor="#E53935"
                app:strokeColor="#E53935" />
        </LinearLayout>
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>